# OjasGo Environment Configuration
# Copy this file to .env and fill in your values

# Your Gemini API Key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask secret key (change this to a random string in production)
SECRET_KEY=ojasgo-change-this-secret-2026

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True
